      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import io\n",
        "\n",
        "csv_data = \"\"\"\n",
        "Patient_ID,Age,Disease,Admission_Date\n",
        "1,25,Fever,2025-01-10\n",
        "2,60,Diabetes,2025-01-15\n",
        "3,45,Fever,2025-02-05\n",
        "4,70,Heart Disease,2025-02-20\n",
        "5,30,Diabetes,2025-03-01\n",
        "6,18,Fever,2025-03-10\n",
        "7,55,Diabetes,2025-04-12\n",
        "8,40,Heart Disease,2025-04-18\n",
        "9,22,Fever,2025-05-05\n",
        "10,65,Diabetes,2025-05-20\n",
        "\"\"\"\n",
        "\n",
        "df = pd.read_csv(io.StringIO(csv_data))\n",
        "print(df)\n",
        "print(df.head())\n",
        "print(df.info())\n",
        "print(df.isnull().sum())\n",
        "df=df.drop_duplicates()\n",
        "print(df)\n",
        "df[\"Admission_Date\"]=pd.to_datetime(df[\"Admission_Date\"])\n",
        "print(df.dtypes)\n",
        "disease_count=df[\"Disease\"].value_counts()\n",
        "print(disease_count)\n",
        "disease_count.plot(kind=\"bar\")\n",
        "plt.title(\"patien count by Disease\")\n",
        "plt.xlabel(\"Disease\")\n",
        "plt.ylabel(\"number of patiens\")\n",
        "plt.show()\n",
        "\n",
        "bin=[0,10,35,50,100]\n",
        "lables=[\"0-18\",\"19-35\",\"36-50\",\"50+\"]\n",
        "df[\"Age_Group\"]=pd.cut(\n",
        "    df[\"Age\"],\n",
        "    bins=bin,\n",
        "    labels=lables\n",
        ")\n",
        "print(df[[\"Age\",\"Age_Group\"]])\n",
        "\n",
        "age_group_count=df[\"Age_Group\"].value_counts()\n",
        "print(age_group_count)\n",
        "age_group_count.plot(kind=\"pie\",autopct=\"%1.1f%%\")\n",
        "\n",
        "plt.title(\"pantie Distribution by Age Group\")\n",
        "plt.ylabel(\"\")\n",
        "plt.show()\n",
        "\n",
        "df[\"Month\"]=df[\"Admission_Date\"].dt.month_name()\n",
        "print(df[[\"Admission_Date\",\"Month\"]])\n",
        "\n",
        "month_admission=df[\"Month\"].value_counts()\n",
        "print(month_admission)\n",
        "\n",
        "peak_month=month_admission.idxmax()\n",
        "print(\"Peak Admission Month\",peak_month)\n",
        "month=df.groupby(\n",
        "    df[\"Admission_Date\"].dt.to_period(\"M\")\n",
        ").size()\n",
        "\n",
        "month.plot(\n",
        "    kind=\"line\",\n",
        "    marker=\"o\"\n",
        ")\n",
        "\n",
        "plt.title(\"Monthly Pstient Admission\")\n",
        "plt.xlabel(\"Month\")\n",
        "plt.ylabel(\"Pstients\")\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()"
